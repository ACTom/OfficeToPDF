# 复制为 .env 并按需修改：cp .env.sample .env

# API 鉴权 Key（必填，请改成强随机值，切勿用默认值）
APIKEY=changeme

# 转换超时时间（秒）
CONVERT_TIMEOUT=600

# 同时可转换数量（不设则默认 CPU 核心数）
MAX_CONCURRENCY=2

# 文件清理时间（秒），从任务完成后的最后修改时间起算
CLEANUP_AFTER_SECONDS=3600

# 日志目录
LOG_DIR=/tmp/o2plog

# 数据目录
DATA_DIR=/tmp/o2pdata

# 失败重试次数（不含首次）
MAX_RETRIES=2

# 队列长度上限（0 表示不限制）
MAX_QUEUE_SIZE=1000

# 任务记录保留时长（秒，默认一天）
JOB_RECORD_TTL_SECONDS=86400

# 日志轮转与级别
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10
LOG_LEVEL=INFO
